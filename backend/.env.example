APP_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=pigtex
DATABASE_URL=

# Auth
JWT_SECRET_KEY=change-this-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=https://app.example.com,null,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Redis-backed runtime features
REDIS_URL=
RATE_LIMIT_BACKEND=memory
IDEMPOTENCY_BACKEND=memory
OAUTH_STATE_BACKEND=auto
ENABLE_RATE_LIMIT=true
ENABLE_IDEMPOTENCY=true
REQUIRE_DB_MIGRATION_HEAD_ON_STARTUP=true
HOST=0.0.0.0
PORT=3001

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
TEXAPI_PARTNER_ENABLED=false
TEXAPI_PARTNER_CLIENT_ID=
TEXAPI_PARTNER_CLIENT_SECRET=
TEXAPI_PARTNER_WEBHOOK_SIGNING_SECRET=

# Optional cloud backup
CLOUD_BACKUP_ENABLED=false
SPACES_REGION=
SPACES_ENDPOINT_URL=
SPACES_BUCKET_BACKUPS=
SPACES_BUCKET_SHARED=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_CDN_URL=
SPACES_ADDRESSING_STYLE=virtual
SPACES_SIGNED_URL_TTL_SECONDS=900

# PigTex Sync billing via PayOS
SYNC_BILLING_ENABLED=false
SYNC_BILLING_PROVIDER=mock
SYNC_CHECKOUT_SUCCESS_URL=https://app.example.com/billing/sync/success
SYNC_CHECKOUT_CANCEL_URL=https://app.example.com/billing/sync/cancel
SYNC_PORTAL_RETURN_URL=https://app.example.com/settings/billing
SYNC_PAYOS_CLIENT_ID=
SYNC_PAYOS_API_KEY=
SYNC_PAYOS_CHECKSUM_KEY=
SYNC_PAYOS_PARTNER_CODE=
SYNC_PAYOS_PAYMENT_LINK_EXPIRY_MINUTES=30
