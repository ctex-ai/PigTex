APP_ENV=production

# Database
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace-with-real-db-password
DB_NAME=pigtex
DATABASE_URL=

# Auth
JWT_SECRET_KEY=replace-with-64-char-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Network / runtime
HOST=0.0.0.0
PORT=3001
CORS_ORIGINS=https://app.example.com,null
AUTO_CREATE_DB_SCHEMA=false
REQUIRE_DB_MIGRATION_HEAD_ON_STARTUP=true

# Optional private prompt/data packs outside this public repo
PIGTEX_DATA_DIR=
PIGTEX_PROMPT_PACKS_DIR=
PIGTEX_SKILL_FOUNDRY_DIR=

# Redis-backed runtime features
REDIS_URL=redis://:replace-with-redis-password@redis:6379/0
ENABLE_RATE_LIMIT=true
RATE_LIMIT_BACKEND=redis
ENABLE_IDEMPOTENCY=true
IDEMPOTENCY_BACKEND=redis
OAUTH_STATE_BACKEND=redis

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloud backup / Spaces
CLOUD_BACKUP_ENABLED=false
SPACES_REGION=sgp1
SPACES_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
SPACES_BUCKET_BACKUPS=
SPACES_BUCKET_SHARED=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_CDN_URL=
SPACES_ADDRESSING_STYLE=virtual
SPACES_SIGNED_URL_TTL_SECONDS=900

# PigTex Sync billing via PayOS
SYNC_BILLING_ENABLED=false
SYNC_BILLING_PROVIDER=mock
SYNC_CHECKOUT_SUCCESS_URL=https://app.example.com/billing/sync/success
SYNC_CHECKOUT_CANCEL_URL=https://app.example.com/billing/sync/cancel
SYNC_PORTAL_RETURN_URL=https://app.example.com/settings/billing
SYNC_PAYOS_CLIENT_ID=
SYNC_PAYOS_API_KEY=
SYNC_PAYOS_CHECKSUM_KEY=
SYNC_PAYOS_PARTNER_CODE=
SYNC_PAYOS_PAYMENT_LINK_EXPIRY_MINUTES=30
