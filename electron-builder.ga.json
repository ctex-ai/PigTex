{
  "extends": "./electron-builder.base.json",
  "afterPack": "./scripts/after-pack-sign-windows.cjs",
  "forceCodeSigning": true,
  "publish": [
    {
      "provider": "github",
      "owner": "ctex-ai",
      "repo": "PigTex",
      "releaseType": "release"
    }
  ],
  "win": {
    "signAndEditExecutable": false,
    "signtoolOptions": {
      "sign": "./scripts/custom-windows-sign.cjs"
    }
  },
  "nsis": {
    "artifactName": "PigTex-${version}.exe"
  }
}
